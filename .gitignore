# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native — build artifacts only (source files ARE committed)
ios/Pods/
ios/build/
ios/.xcode.env.local
android/.gradle/
android/build/
android/app/build/
android/.kotlin/
.kotlin/

# Keystore / signing (secrets — never commit)
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.keystore

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# Environment variables (secrets)
.env
.env.local
.env*.local

# typescript
*.tsbuildinfo

# Misc
*.orig.*
